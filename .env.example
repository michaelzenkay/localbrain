# Copy this file to .env and change the access key before first use.

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=<local-supabase-service-role-key>
MCP_ACCESS_KEY=<localbrain-key>
# "*" means this key can access every namespace.
MCP_ACCESS_KEY_SCOPES=*
# Optional scoped keys. Format:
# label:key:namespace1|namespace2
# admin:<admin-key>:*
# journal-client:<journal-key>:localbrain|journal
MCP_ACCESS_KEYS=

# Ollama's OpenAI-compatible API. When Supabase runs in Docker,
# host.docker.internal reaches Ollama on the host machine.
OLLAMA_BASE=http://host.docker.internal:11434/v1
OLLAMA_EMBED_MODEL=mxbai-embed-large
# Used only for short JSON metadata extraction. Prefer an instruct model over
# a reasoning-oriented model so captures stay fast and schema-shaped.
OLLAMA_CHAT_MODEL=qwen2.5:4b-instruct
OLLAMA_LOCAL_ONLY=true

DEFAULT_BRAIN_ID=localbrain
NODE_ID=local
AGENT_ID=mcp
SOURCE_CLIENT=localbrain-stdio
LOCALBRAIN_MCP_URL=http://127.0.0.1:54321/functions/v1/local-memory-mcp
